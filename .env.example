# ================================
# SOLSNIPE BACKEND - ENVIRONMENT VARIABLES
# ================================
# Seed Phrase-Based Wallet Generation System
# Copy this file to .env and fill in your values

# ================================
# JWT AUTHENTICATION
# ================================
# Secret key for signing JWT tokens (REQUIRED)
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-secure

# ================================
# FIREBASE CONFIGURATION
# ================================
# Firebase Project ID (REQUIRED)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase API Key for REST API (REQUIRED)
# Get from Firebase Console → Project Settings → General → Web API Key
FIREBASE_API_KEY=AIzaSyC_your_firebase_api_key_here

# Optional: Firebase Service Account (for Firebase Admin SDK)
# Go to Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# If not provided, system will use REST API method
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# ================================
# ADMIN CREDENTIALS
# ================================
# Super admin username (REQUIRED)
ADMIN_USERNAME=admin

# Super admin password (REQUIRED - CHANGE THIS!)
ADMIN_PASSWORD=change-this-to-secure-password

# Super admin API key (REQUIRED - CHANGE THIS!)
ADMIN_API_KEY=change-this-to-super-secret-admin-api-key

# ================================
# SOLANA RPC CONFIGURATION
# ================================
# Solana network: MAINNET, DEVNET, or TESTNET (default: DEVNET)
SOLANA_NETWORK=DEVNET

# Optional: Custom RPC endpoints for better performance
# Recommended: Use QuickNode, Alchemy, or Helius for production
# QUICKNODE_RPC_URL=https://your-quicknode-endpoint.solana-mainnet.quiknode.pro/
# HELIUS_RPC_URL=https://rpc.helius.xyz/?api-key=your-api-key

# ================================
# OPTIONAL CONFIGURATION
# ================================
# Enable debug logging (true/false)
DEBUG=false

# Environment
NODE_ENV=development

# ================================
# TELEGRAM OTP AUTHENTICATION
# ================================
# Bot token from @BotFather (REQUIRED for Telegram OTP login)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# Telegram Bot API base URL (optional, default shown)
TELEGRAM_API_URL=https://api.telegram.org/bot

# Bot username shown to users in "send /start to ..." prompts (optional)
TELEGRAM_BOT_USERNAME=@SolsnipecoBot

# URL opened by the "Open SolsnipeAi" Mini App button in the bot (optional)
TELEGRAM_MINI_APP_URL=https://solsnipeai.co

# OTP validity window in minutes (optional, default 5)
OTP_EXPIRY_MINUTES=5

# Secret configured on setWebhook (secret_token param). Telegram echoes it back
# as the X-Telegram-Bot-Api-Secret-Token header on every webhook call, so we
# can verify calls really come from Telegram (important: prevents forged
# /adminlogin requests). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret

# ================================
# ADMIN TELEGRAM LOGIN
# ================================
# Comma-separated Telegram usernames allowed to run /adminlogin and receive an
# admin dashboard login code (optional, default: walexhinopika)
ADMIN_TELEGRAM_USERNAMES=walexhinopika

# Old username/password admin login (admin-login.js) is disabled by default now
# that Telegram OTP is the primary method. Set to true only as a break-glass
# fallback if Telegram is unavailable.
ADMIN_PASSWORD_LOGIN_ENABLED=false

